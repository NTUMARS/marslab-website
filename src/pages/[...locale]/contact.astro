---
import { i18n } from "astro:config/client";
import Base from "$layouts/Base.astro";
import i18nit from "$i18n";
import Icon from "$components/Icon.astro";

export async function getStaticPaths() {
    return i18n?.locales.map(locale => ({ params: { locale: locale == i18n?.defaultLocale ? undefined : (locale as string) } }));
}

const { locale = i18n!.defaultLocale } = Astro.params;
const t = i18nit(locale);

// External-link helper — accent "link ↗" anchor used inline.
const link = (href: string, label = "link") =>
	`<a class="opening-link" href="${href}" target="_blank" rel="noopener noreferrer">${label} ↗</a>`;

// PhD scholarships (names from marsyang.site/group; links provided by PI).
const scholarships = [
	"Nanyang Research Scholarship (normal, $3200/month after QE)",
	`Interdisciplinary Graduate Programme (IGP) ${link("https://www.ntu.edu.sg/graduate-college/admissions/programme/interdisciplinary-graduate-programme/admission-requirement#Content_C011_Col00")}`,
	`AISG Scholarship ($6300/month) ${link("https://aisingapore.org/research/phd-fellowship-programme/")}`,
	`Singapore International Graduate Award (SINGA) ${link("https://www.a-star.edu.sg/Scholarships/for-graduate-studies/singapore-international-graduate-award-singa")}`,
	`Nanyang President's Graduate Scholarship (NPGS) ${link("https://www.ntu.edu.sg/admissions/graduate/financialmatters/scholarships/npgs")}`,
];

// Each section renders an ordered set of blocks: paragraphs, bullet lists,
// and (optionally) a nested sub-list under a bullet. html is trusted, static.
const opportunities = [
	{
		title: "PhD Students",
		icon: "lucide:graduation-cap",
		blocks: [
			{ type: "p", html: "We are actively recruiting highly motivated PhD students who are passionate about robotics, embodied AI, and machine learning." },
			{ type: "list", items: [
				"Email Prof. Jianfei Yang with their CV and a brief introduction of their research interests.",
				{ html: "Review the available scholarship opportunities before applying, including:", sublist: scholarships },
			] },
		],
	},
	{
		title: "Postdoctoral Researchers",
		icon: "lucide:briefcase",
		blocks: [
			{ type: "p", html: "We welcome applications from outstanding postdoctoral researchers. Interested candidates should email Prof. Jianfei Yang with the following materials:" },
			{ type: "list", items: [
				"Curriculum Vitae (CV)",
				"One-page research statement",
				"Contact information for references",
				"At least one representative publication or project",
			] },
		],
	},
	{
		title: "Master's Students",
		icon: "lucide:book-open",
		blocks: [
			{ type: "p", html: "We currently supervise NTU Master's students only. Before contacting us, please review the research interests of our lab members and identify the research direction that best aligns with your interests. Applicants should email at least one relevant lab member and Prof. Jianfei Yang." },
			{ type: "p", html: "As the Master's dissertation carries academic units in NTU, applicants should ensure a minimum commitment of 15 hours per week to research activities before reaching out." },
		],
	},
	{
		title: "Undergraduate Students",
		icon: "lucide:school",
		blocks: [
			{ type: "p", html: `We welcome NTU undergraduate students through the URECA programme (${link("https://www.ntu.edu.sg/education/undergraduate-research-experience-on-campus-(ureca)")}) and other undergraduate research opportunities. Interested students are encouraged to contact Prof. Jianfei Yang with their CV and research interests.` },
		],
	},
	{
		title: "Visiting Researchers",
		icon: "lucide:globe",
		blocks: [
			{ type: "p", html: "We welcome visiting undergraduate students, graduate students, and researchers from around the world." },
			{ type: "list", items: [
				"Visiting graduate and PhD students: minimum stay of 6 months",
				"Undergraduate summer research students: minimum stay of 3 months",
			] },
			{ type: "p", html: "Prospective visitors should contact Jianfei with their CV, expected visit duration, and a brief description of their research interests." },
		],
	},
	{
		title: "Application Note",
		icon: "lucide:info",
		blocks: [
			{ type: "p", html: "Due to the large number of inquiries we receive, we are unfortunately unable to respond to every application. We will only contact shortlisted candidates for further discussion. Thank you for your interest in MARS Lab and for your understanding." },
		],
	},
];
---

<Base title="Contact" {locale}>
	<main class="flex flex-col grow">
		<h1 class="text-3xl font-bold mb-6">Contact</h1>

		<p class="intro-text">
			We welcome researchers from diverse backgrounds related to robotics, embodied AI, machine learning,
			computer vision, human–robot interaction, cognitive science, and other fields relevant to intelligent
			physical agents. We are always open to new collaborations and interdisciplinary research opportunities.
		</p>

		<p class="intro-text">
			For research collaborations, please feel free to directly contact the relevant MARS Lab member whose
			research interests best match your topic.
		</p>

		<h2 class="join-heading">Join Us</h2>

		<section class="openings">
			{opportunities.map((opp) => (
				<article class="opening">
					<div class="opening-head">
						<span class="opening-icon"><Icon name={opp.icon} size={20} inline /></span>
						<h3 class="opening-title">{opp.title}</h3>
					</div>

					<div class="opening-content">
						{opp.blocks.map((block) => (
							block.type === "p" ? (
								<p class="opening-desc" set:html={block.html} />
							) : (
								<ul class="opening-details">
									{block.items.map((item) => (
										typeof item === "string" ? (
											<li set:html={item} />
										) : (
											<li>
												<span set:html={item.html} />
												{item.sublist && (
													<ul class="opening-subdetails">
														{item.sublist.map((s) => <li set:html={s} />)}
													</ul>
												)}
											</li>
										)
									))}
								</ul>
							)
						))}
					</div>
				</article>
			))}
		</section>
	</main>
</Base>

<style>
	.intro-text {
		font-size: 1.05rem;
		line-height: 1.75;
		color: var(--secondary-color);
		max-width: none;
		margin: 0 0 1rem 0;
	}

	.intro-text:last-of-type {
		margin-bottom: 0.5rem;
	}

	.join-heading {
		font-size: 1.6rem;
		font-weight: 700;
		color: var(--primary-color);
		margin: 1.8rem 0 0;
	}

	/* Editorial listing — no cards/boxes, entries separated by thin rules */
	.openings {
		display: flex;
		flex-direction: column;
	}

	.opening {
		display: flex;
		flex-direction: column;
		gap: 0.85rem;
		padding: 2rem 0;
		border-top: 1px solid var(--shadow-color);
	}

	.opening:last-child {
		border-bottom: 1px solid var(--shadow-color);
	}

	.opening-head {
		display: flex;
		align-items: flex-start;
		gap: 0.55rem;
	}

	.opening-icon {
		display: inline-flex;
		color: var(--accent);
		margin-top: 0.15rem;
		flex-shrink: 0;
	}

	.opening-icon :global(figure) {
		display: flex;
		margin: 0;
	}

	.opening-title {
		font-size: 1.25rem;
		font-weight: 600;
		line-height: 1.3;
		color: var(--primary-color);
		margin: 0;
	}

	.opening-content {
		min-width: 0;
	}

	.opening-desc {
		font-size: 1rem;
		line-height: 1.65;
		color: var(--primary-color);
		margin: 0 0 0.85rem 0;
	}

	.opening-desc:last-child {
		margin-bottom: 0;
	}

	.opening-details {
		list-style: none;
		padding: 0;
		margin: 0 0 0.4rem 0;
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}

	.opening-details > li {
		font-size: 0.95rem;
		line-height: 1.6;
		color: var(--secondary-color);
		padding-left: 1.2rem;
		position: relative;
	}

	.opening-details > li::before {
		content: "▸";
		position: absolute;
		left: 0;
		color: var(--accent);
	}

	/* Nested sub-list (e.g. PhD scholarships) */
	.opening-subdetails {
		list-style: none;
		padding: 0;
		margin: 0.55rem 0 0 0;
		display: flex;
		flex-direction: column;
		gap: 0.45rem;
	}

	.opening-subdetails li {
		font-size: 0.92rem;
		line-height: 1.55;
		color: var(--secondary-color);
		padding-left: 1.4rem;
		position: relative;
	}

	.opening-subdetails li::before {
		content: "✓";
		position: absolute;
		left: 0;
		top: 0.02em;
		color: var(--accent);
		font-weight: 700;
		font-size: 0.85rem;
	}

	/* Inline external links (scholarships, URECA, …) */
	.opening-link {
		color: var(--accent);
		font-weight: 600;
		text-decoration: none;
		white-space: nowrap;
		border-bottom: 1px solid transparent;
		transition: color 0.18s ease, border-color 0.18s ease;
	}

	.opening-link:hover {
		color: var(--accent-deep);
		border-bottom-color: currentColor;
	}

	@media (max-width: 768px) {
		.opening {
			padding: 1.6rem 0;
		}

		.intro-text {
			font-size: 1rem;
		}

		.join-heading {
			font-size: 1.4rem;
		}
	}
</style>
