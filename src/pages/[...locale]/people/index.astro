---
import { i18n } from "astro:config/client";
import Base from "$layouts/Base.astro";
import i18nit from "$i18n";
import Icon from "$components/Icon.astro";
import { people, alumni } from "$data/people";

export async function getStaticPaths() {
	return i18n!.locales.map(locale => ({ params: { locale: locale == i18n?.defaultLocale ? undefined : (locale as string) } }));
}

const { locale = i18n!.defaultLocale } = Astro.params;
const t = i18nit(locale);
const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';

// Anchor id used by the home-page photo links (/people#<id>)
const personId = (name: string) => name.toLowerCase().replace(/[^a-z]/g, '');
const initials = (name: string) => name.split(' ').map(n => n[0]).join('');

// Profile links in a fixed display order (rendered as icon-only chips)
const socialLinks = (p: any) => [
	p.links.website && { icon: "lucide:globe", label: "Website", url: p.links.website },
	p.links.email && { icon: "lucide:mail", label: "Email", url: `mailto:${p.links.email}` },
	p.links.scholar && { icon: "lucide:graduation-cap", label: "Scholar", url: p.links.scholar },
	p.links.github && { icon: "simple-icons:github", label: "GitHub", url: p.links.github },
	p.links.linkedin && { icon: "simple-icons:linkedin", label: "LinkedIn", url: p.links.linkedin },
	p.links.resume && { icon: "lucide:file-search", label: "Résumé", url: p.links.resume },
	p.links.twitter && { icon: "simple-icons:x", label: "Twitter", url: p.links.twitter },
].filter(Boolean) as { icon: string; label: string; url: string }[];

// Group members into role sections (each person lands in exactly one)
const sectionDefs = [
	{ title: "Postdocs", match: (p: any) => p.position === "Postdoc" },
	{ title: "PhD Students", match: (p: any) => p.position.startsWith("PhD") },
	{ title: "MEng Students", match: (p: any) => /MEng|Master/.test(p.position) },
	{ title: "Research Assistants", match: (p: any) => p.position === "Research Assistant" },
];

const pi = people.find(p => p.position === "Principal Investigator");
const sections = sectionDefs
	.map(s => ({ title: s.title, members: people.filter(s.match) }))
	.filter(s => s.members.length > 0);

// Safety net: surface anyone not placed in the PI slot or a section
const placed = new Set([pi, ...sections.flatMap(s => s.members)].filter(Boolean));
const others = people.filter(p => !placed.has(p));
if (others.length) sections.push({ title: "Team", members: others });
---

<Base title={t("navigation.people") || "People"} {locale}>
	<main class="flex flex-col grow">
		<h1 class="text-3xl font-bold mb-8">Martian People</h1>

		{pi && (
			<section class="role-section">
				<h2 class="role-heading">Principal Investigator</h2>
				<article
					class="pi-feature"
					id={personId(pi.name)}
					data-name={pi.name}
					data-role={pi.position}
					data-img={pi.image ? `${baseUrl}${pi.image.replace(/^\//, '')}` : ''}
					data-bio={pi.bio || ''}
					data-research={pi.research || ''}
				>
					<div class="pi-photo">
						{pi.image ? (
							<img src={`${baseUrl}${pi.image.replace(/^\//, '')}`} alt={pi.name} loading="lazy" />
						) : (
							<div class="photo-placeholder"><span>{initials(pi.name)}</span></div>
						)}
					</div>
					<div class="pi-info">
						<h3 class="pi-name">{pi.name}</h3>
						<p class="pi-role">{pi.position}</p>
						{pi.research && <p class="pi-research">{pi.research}</p>}
						{socialLinks(pi).length > 0 && (
							<div class="person-links">
								{socialLinks(pi).map((l) => (
									<a href={l.url} class="person-link" title={l.label} aria-label={l.label} target="_blank" rel="noopener noreferrer">
										<Icon name={l.icon} size={16} />
									</a>
								))}
							</div>
						)}
					</div>
				</article>
			</section>
		)}

		{sections.map((section) => (
			<section class="role-section">
				<h2 class="role-heading">{section.title}</h2>
				<div class="people-grid">
					{section.members.map((person) => (
						<article
							class="person"
							id={personId(person.name)}
							data-name={person.name}
							data-role={person.position}
							data-img={person.image ? `${baseUrl}${person.image.replace(/^\//, '')}` : ''}
							data-bio={person.bio || ''}
							data-research={person.research || ''}
						>
							<div class="person-photo">
								{person.image ? (
									<img src={`${baseUrl}${person.image.replace(/^\//, '')}`} alt={person.name} loading="lazy" />
								) : (
									<div class="photo-placeholder"><span>{initials(person.name)}</span></div>
								)}
							</div>
							<h3 class="person-name">{person.name}</h3>
							<p class="person-role">{person.position}</p>
							{socialLinks(person).length > 0 && (
								<div class="person-links">
									{socialLinks(person).map((l) => (
										<a href={l.url} class="person-link" title={l.label} aria-label={l.label} target="_blank" rel="noopener noreferrer">
											<Icon name={l.icon} size={16} />
										</a>
									))}
								</div>
							)}
						</article>
					))}
				</div>
			</section>
		))}

		<section class="alumni-section">
			<h2 class="alumni-heading">Alumni</h2>
			<p class="alumni-intro">We thank all MARS Lab alumni for their invaluable contributions and wish them bright futures ahead.</p>
			{alumni.map((cohort) => (
				<div class="alumni-group">
					<h3 class="alumni-group-title">{cohort.group}</h3>
					<ul class="alumni-list">
						{cohort.members.map((m) => (
							<li>
								<strong>{m.name}</strong>{m.note ? ` (${m.note})` : ""}{m.topic ? ` — ${m.topic}` : ""} <span class="alumni-period">({m.period})</span>
							</li>
						))}
					</ul>
				</div>
			))}
		</section>

		<!-- Bio modal: opened by clicking a person's photo or name -->
		<div class="bio-modal" id="bioModal" aria-hidden="true">
			<div class="bio-modal-backdrop" data-close></div>
			<div class="bio-modal-card" role="dialog" aria-modal="true" aria-label="Member biography">
				<button class="bio-modal-close" data-close aria-label="Close">✕</button>
				<div class="bio-modal-photo"><img src="" alt="" /></div>
				<div class="bio-modal-info">
					<h3 class="bio-modal-name"></h3>
					<p class="bio-modal-role"></p>
					<div class="bio-modal-bio"></div>
					<div class="bio-modal-links person-links"></div>
				</div>
			</div>
		</div>
	</main>
</Base>

<style>
	/* Role sections */
	.role-section {
		margin-bottom: 3.5rem;
	}

	.role-heading {
		font-size: 1.4rem;
		font-weight: 700;
		color: var(--primary-color);
		margin: 0 0 1.5rem 0;
		padding-bottom: 0.4rem;
		border-bottom: 2px solid var(--accent);
		display: inline-block;
	}

	/* Featured PI block */
	.pi-feature {
		display: grid;
		grid-template-columns: 200px 1fr;
		gap: 2rem;
		align-items: start;
		scroll-margin-top: 5rem;
	}

	.pi-photo {
		width: 200px;
		aspect-ratio: 1 / 1;
		border-radius: 8px;
		overflow: hidden;
		border: 1px solid var(--shadow-color);
		background: var(--block-color);
	}

	.pi-photo img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.pi-info {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		min-width: 0;
	}

	.pi-name {
		font-size: 1.6rem;
		font-weight: 700;
		color: var(--primary-color);
		margin: 0;
		line-height: 1.2;
	}

	.pi-role {
		font-size: 1rem;
		font-weight: 500;
		color: var(--secondary-color);
		margin: 0;
	}

	.pi-research {
		font-size: 0.98rem;
		line-height: 1.65;
		color: var(--primary-color);
		margin: 0.4rem 0 0.2rem 0;
		max-width: 66ch;
	}

	/* Member grid */
	.people-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
		gap: 2rem 1.5rem;
	}

	.person {
		display: flex;
		flex-direction: column;
		scroll-margin-top: 5rem;
	}

	.person-photo {
		width: 100%;
		aspect-ratio: 1 / 1;
		border-radius: 8px;
		overflow: hidden;
		background: var(--block-color);
		border: 1px solid var(--shadow-color);
	}

	.person-photo img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.photo-placeholder {
		width: 100%;
		height: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
		background: linear-gradient(135deg, var(--block-color) 0%, var(--shadow-color) 100%);
		font-size: 2rem;
		font-weight: 600;
		color: var(--secondary-color);
		text-transform: uppercase;
	}

	.person-name {
		font-size: 1.05rem;
		font-weight: 600;
		color: var(--primary-color);
		margin: 0.7rem 0 0.1rem 0;
		line-height: 1.3;
	}

	.person-role {
		font-size: 0.85rem;
		color: var(--secondary-color);
		margin: 0;
	}

	/* Icon-only profile links */
	.person-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.25rem;
		margin-top: 0.6rem;
	}

	.person-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 28px;
		height: 28px;
		background: var(--block-color);
		color: var(--accent);
		border-radius: 6px;
		text-decoration: none;
		transition: background 0.2s ease, transform 0.1s ease;
	}

	.person-link:hover {
		background: var(--accent-soft);
		transform: translateY(-2px);
	}

	.person-link :global(figure) {
		display: flex;
		align-items: center;
		margin: 0;
	}

	.person-link :global(svg) {
		width: 16px;
		height: 16px;
		flex-shrink: 0;
	}

	/* Photo & name are clickable to open the bio modal */
	.person-photo,
	.person-name,
	.pi-photo,
	.pi-name {
		cursor: pointer;
	}

	.person-name:hover,
	.pi-name:hover {
		color: var(--accent);
	}

	/* Bio modal */
	.bio-modal {
		position: fixed;
		inset: 0;
		z-index: 100;
		display: none;
		align-items: center;
		justify-content: center;
		padding: 1.5rem;
	}

	.bio-modal.open {
		display: flex;
	}

	.bio-modal-backdrop {
		position: absolute;
		inset: 0;
		background: rgba(15, 15, 15, 0.35);
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
		animation: bm-fade 0.2s ease;
	}

	.bio-modal-card {
		position: relative;
		z-index: 1;
		display: grid;
		grid-template-columns: 260px 1fr;
		gap: 1.75rem;
		width: min(700px, 100%);
		height: min(440px, 85vh);
		background: var(--background-color);
		border: 1px solid var(--shadow-color);
		border-radius: 14px;
		box-shadow: 0 24px 60px rgba(0, 0, 0, 0.3);
		padding: 1.75rem;
		animation: bm-pop 0.25s cubic-bezier(0.2, 0.8, 0.2, 1);
	}

	@keyframes bm-fade {
		from { opacity: 0; }
		to { opacity: 1; }
	}

	@keyframes bm-pop {
		from { opacity: 0; transform: translateY(10px) scale(0.96); }
		to { opacity: 1; transform: translateY(0) scale(1); }
	}

	/* Photo is vertically centered in the (taller) fixed-height column */
	.bio-modal-photo {
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.bio-modal-photo img {
		width: 100%;
		aspect-ratio: 1 / 1;
		object-fit: cover;
		border-radius: 10px;
		border: 1px solid var(--shadow-color);
		display: block;
	}

	/* Right column: name/role pinned, bio scrolls, links pinned */
	.bio-modal-info {
		display: flex;
		flex-direction: column;
		min-width: 0;
		min-height: 0;
	}

	.bio-modal-name {
		font-size: 1.5rem;
		font-weight: 700;
		color: var(--primary-color);
		margin: 0;
		line-height: 1.2;
		flex-shrink: 0;
	}

	.bio-modal-role {
		font-size: 0.95rem;
		color: var(--secondary-color);
		margin: 0.2rem 0 0.75rem 0;
		flex-shrink: 0;
	}

	.bio-modal-bio {
		flex: 1 1 auto;
		min-height: 0;
		overflow-y: auto;
		padding-right: 0.5rem;
	}

	.bio-modal-bio :global(p) {
		font-size: 0.92rem;
		line-height: 1.65;
		color: var(--primary-color);
		margin: 0 0 0.7rem 0;
	}

	.bio-modal-bio :global(p:last-child) {
		margin-bottom: 0;
	}

	.bio-modal-links {
		flex-shrink: 0;
		margin-top: 0.4rem;
		padding-top: 0.85rem;
		border-top: 1px solid var(--shadow-color);
	}

	.bio-modal-close {
		position: absolute;
		top: 0.7rem;
		right: 0.7rem;
		width: 32px;
		height: 32px;
		border: none;
		background: var(--block-color);
		color: var(--secondary-color);
		border-radius: 50%;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 1.1rem;
		line-height: 1;
		z-index: 2;
		transition: background 0.2s ease, color 0.2s ease;
	}

	.bio-modal-close:hover {
		background: var(--shadow-color);
		color: var(--primary-color);
	}

	:global(body.modal-open) {
		overflow: hidden;
	}

	@media (max-width: 640px) {
		.bio-modal-card {
			grid-template-columns: 1fr;
			gap: 1rem;
			height: auto;
			max-height: 85vh;
			overflow-y: auto;
		}

		.bio-modal-photo img {
			width: 180px;
		}

		/* On mobile the whole card scrolls, so the bio doesn't need its own scroll */
		.bio-modal-bio {
			overflow: visible;
			padding-right: 0;
		}

		.bio-modal-links {
			border-top: none;
			padding-top: 0.4rem;
		}
	}

	/* Alumni — plain text list */
	.alumni-section {
		margin-top: 1rem;
	}

	.alumni-heading {
		font-size: 1.4rem;
		font-weight: 700;
		color: var(--primary-color);
		margin: 0 0 0.75rem 0;
		padding-bottom: 0.4rem;
		border-bottom: 2px solid var(--accent);
		display: inline-block;
	}

	.alumni-intro {
		color: var(--secondary-color);
		margin: 0 0 1.5rem 0;
	}

	.alumni-group {
		margin-bottom: 1.75rem;
	}

	.alumni-group-title {
		font-size: 1.1rem;
		font-weight: 600;
		color: var(--primary-color);
		margin: 0 0 0.6rem 0;
	}

	.alumni-list {
		list-style: disc;
		padding-left: 1.25rem;
		display: flex;
		flex-direction: column;
		gap: 0.45rem;
	}

	.alumni-list li {
		color: var(--secondary-color);
		line-height: 1.6;
	}

	.alumni-list strong {
		color: var(--primary-color);
	}

	.alumni-period {
		color: var(--remark-color);
		white-space: nowrap;
	}

	/* Responsive */
	@media (max-width: 600px) {
		.pi-feature {
			grid-template-columns: 1fr;
			gap: 1.25rem;
		}

		.pi-photo {
			width: 150px;
		}

		.people-grid {
			grid-template-columns: repeat(auto-fill, minmax(125px, 1fr));
			gap: 1.5rem 1rem;
		}

		.person-name {
			font-size: 0.98rem;
		}
	}
</style>
