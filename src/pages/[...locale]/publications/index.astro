---
import { getCollection } from "astro:content";
import { i18n } from "astro:config/client";
import Base from "$layouts/Base.astro";
import Icon from "$components/Icon.astro";
import i18nit from "$i18n";

export async function getStaticPaths() {
	// Create path for each locale, omitting default locale from URL
	return i18n!.locales.map(locale => ({ params: { locale: locale == i18n?.defaultLocale ? undefined : (locale as string) } }));
}

const { locale = i18n!.defaultLocale } = Astro.params;

const t = i18nit(locale);
const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';

const publications = await getCollection("publications", publication => !publication.data.draft);

// Canonical research-area order for the topic filter (matches the tags on each paper)
const RESEARCH_AREAS = [
	"World Models",
	"Vision-Language-Action",
	"Reinforcement Learning",
	"Humanoid Robot",
	"Robot Manipulation",
	"Vision-Language Models",
	"Multimodal Foundation Models",
	"RF Sensing",
	"Wireless Human Sensing",
	"Domain Adaptation",
	"Video Understanding",
	"Efficient AI",
	"Benchmarks & Datasets",
];

// Rank a tag by the canonical order (unknown tags sort last)
const areaRank = (area: string) => {
	const i = RESEARCH_AREAS.indexOf(area);
	return i === -1 ? RESEARCH_AREAS.length : i;
};

// Order a paper's tags by the canonical research-area order
const orderedTags = (tags?: string[]) => [...(tags ?? [])].sort((a, b) => areaRank(a) - areaRank(b));

// Primary link for a paper — title and thumbnail point here
const primaryLink = (pub: any): string | undefined => pub.data.paper || pub.data.website || pub.data.code || undefined;

// Show the venue, appending the year only when the venue text doesn't already contain one
const venueLabel = (venue: string, year: number) => /\d{4}/.test(venue) ? venue : `${venue} ${year}`;

// Preprint vs published: arXiv-only entries are preprints, everything else is a published venue
const pubStatus = (venue: string): "preprint" | "published" => /arxiv|preprint/i.test(venue) ? "preprint" : "published";

// Within-year recency key (newest first). Prefer an explicit `date` (YYYY-MM),
// otherwise parse the month from the arXiv id (arxiv.org/abs|pdf/YYMM.NNNNN).
// Returns a YYMM number; 0 when unknown (sorts last within its year).
const recencyKey = (pub: any): number => {
	const explicit = String(pub.data.date ?? "").match(/^(\d{4})-(\d{2})/);
	if (explicit) return parseInt(explicit[1].slice(2) + explicit[2]);
	const arxiv = String(pub.data.paper ?? "").match(/arxiv\.org\/(?:abs|pdf)\/(\d{2})(\d{2})\./);
	if (arxiv) return parseInt(arxiv[1] + arxiv[2]);
	return 0;
};

// Sort newest first: year desc → recency (month) desc → title
const sortedPublications = publications.sort((a, b) => {
	if (b.data.year !== a.data.year) return b.data.year - a.data.year;
	const diff = recencyKey(b) - recencyKey(a);
	if (diff !== 0) return diff;
	return a.data.title.localeCompare(b.data.title);
});

// Build the filter lists
const years = Array.from(new Set(publications.map(pub => pub.data.year))).sort((a, b) => b - a);

// Research areas present, ordered by the canonical taxonomy (any stray tags appended at the end)
const presentAreas = new Set(publications.flatMap(pub => pub.data.tags ?? []));
const knownAreas = RESEARCH_AREAS.filter(a => presentAreas.has(a));
const extraAreas = Array.from(presentAreas).filter(a => !RESEARCH_AREAS.includes(a)).sort();
const areas = [...knownAreas, ...extraAreas];
---

<Base title={t("navigation.publications") || "Publications"} {locale}>
	<main class="flex flex-col grow">
		<h1 class="text-3xl font-bold mb-8">Publications</h1>

		<div class="publications-container">
			<!-- Publications list: one row per paper -->
			<div class="publications-main">
				<div class="publications-grid">
					{sortedPublications.map((pub) => {
						const link = primaryLink(pub);
						const thumb = pub.data.image ? (
							<img src={`${baseUrl}${pub.data.image.replace(/^\//, '')}`} alt={pub.data.title} loading="lazy" />
						) : (
							<div class="placeholder-image"><span class="year-badge">{pub.data.year}</span></div>
						);
						return (
						<article class="publication-card" data-year={pub.data.year} data-tags={orderedTags(pub.data.tags).join("|")} data-status={pubStatus(pub.data.venue)}>
							<div class="pub-aside">
								{link ? (
									<a class="pub-thumb" href={link} target="_blank" rel="noopener noreferrer">{thumb}</a>
								) : (
									<div class="pub-thumb">{thumb}</div>
								)}

								<div class="pub-venue-row">
									<span class="pub-venue">{venueLabel(pub.data.venue, pub.data.year)}</span>
									{pub.data.award && <span class="award-badge">{pub.data.award}</span>}
								</div>
							</div>

							<div class="pub-body">
								<h2 class="publication-title">
									{link ? (
										<a href={link} target="_blank" rel="noopener noreferrer">{pub.data.title}</a>
									) : pub.data.title}
								</h2>

								<p class="publication-authors">{pub.data.authors.join(", ")}</p>

								{pub.data.tags && pub.data.tags.length > 0 && (
									<div class="publication-topics">
										{orderedTags(pub.data.tags).map((tag) => (
											<span class="topic-tag">{tag}</span>
										))}
									</div>
								)}

								{(pub.data.paper || pub.data.website || pub.data.code) && (
									<div class="publication-links">
										{pub.data.paper && (
											<a href={pub.data.paper} target="_blank" rel="noopener noreferrer" class="pub-link">
												<Icon name="lucide:file-text" size={16} />
												<span>Paper</span>
											</a>
										)}
										{pub.data.website && (
											<a href={pub.data.website} target="_blank" rel="noopener noreferrer" class="pub-link">
												<Icon name="lucide:globe" size={16} />
												<span>Website</span>
											</a>
										)}
										{pub.data.code && (
											<a href={pub.data.code} target="_blank" rel="noopener noreferrer" class="pub-link">
												<Icon name="lucide:code" size={16} />
												<span>Code</span>
											</a>
										)}
									</div>
								)}
							</div>
						</article>
						);
					})}
				</div>
			</div>

			<!-- Filter sidebar (right): Research Topic scrolls; Year and Status below -->
			<aside class="publications-sidebar">
				<section class="filter-section">
					<h3>Research Topic</h3>
					<div class="filter-group filter-scrollable">
						{areas.map((area) => (
							<label class="filter-label">
								<input type="checkbox" class="filter-checkbox area-filter" data-value={area} />
								<span>{area}</span>
							</label>
						))}
					</div>
				</section>

				<section class="filter-section">
					<h3>Year</h3>
					<div class="filter-group">
						{years.map((year) => (
							<label class="filter-label">
								<input type="checkbox" class="filter-checkbox year-filter" data-value={year} />
								<span>{year}</span>
							</label>
						))}
					</div>
				</section>

				<section class="filter-section">
					<h3>Status</h3>
					<div class="filter-group">
						<label class="filter-label">
							<input type="checkbox" class="filter-checkbox status-filter" data-value="preprint" />
							<span>Preprint</span>
						</label>
						<label class="filter-label">
							<input type="checkbox" class="filter-checkbox status-filter" data-value="published" />
							<span>Published</span>
						</label>
					</div>
				</section>
			</aside>

		</div>
	</main>
</Base>

<style>
	.publications-container {
		display: grid;
		grid-template-columns: 1fr 210px;
		gap: 3rem;
		width: 100%;
		align-items: start;
	}

	/* Filter sidebar — right column, sticky */
	.publications-sidebar {
		position: sticky;
		top: 1rem;
		height: fit-content;
		display: flex;
		flex-direction: column;
		gap: 1.6rem;
	}

	.filter-section {
		display: flex;
		flex-direction: column;
		gap: 0.55rem;
		margin: 0;
	}

	.filter-section h3 {
		font-size: 0.66rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--weak-color);
		margin: 0 0 0.1rem 0;
	}

	.filter-group {
		display: flex;
		flex-direction: column;
		gap: 0.05rem;
	}

	/* Research Topic is long → its own scroll area */
	.filter-scrollable {
		max-height: 224px;
		overflow-y: auto;
		overflow-x: hidden;
		padding-right: 0.4rem;
	}

	.filter-label {
		display: flex;
		align-items: center;
		gap: 0.55rem;
		cursor: pointer;
		font-size: 0.85rem;
		line-height: 1.3;
		color: var(--secondary-color);
		user-select: none;
		padding: 0.26rem 0.35rem;
		border-radius: 5px;
		transition: color 0.15s ease, background-color 0.15s ease;
	}
	.filter-label:hover { color: var(--accent); background: var(--accent-soft); }
	.filter-label:has(.filter-checkbox:checked) { color: var(--accent); font-weight: 600; }

	/* custom amber checkbox */
	.filter-checkbox {
		appearance: none;
		-webkit-appearance: none;
		flex-shrink: 0;
		width: 15px;
		height: 15px;
		margin: 0;
		border: 1.5px solid var(--shadow-color);
		border-radius: 4px;
		background: var(--background-color);
		cursor: pointer;
		position: relative;
		transition: background-color 0.15s ease, border-color 0.15s ease;
	}
	.filter-checkbox:checked {
		background: var(--accent);
		border-color: var(--accent);
	}
	.filter-checkbox:checked::after {
		content: "";
		position: absolute;
		left: 4px;
		top: 1px;
		width: 4px;
		height: 8px;
		border: solid #fffdfb;
		border-width: 0 2px 2px 0;
		transform: rotate(45deg);
	}

	/* Publications list — one row per paper */
	.publications-main {
		min-width: 0;
	}

	.publications-grid {
		display: flex;
		flex-direction: column;
		gap: 1.75rem;
		width: 100%;
	}

	.publication-card {
		display: grid;
		grid-template-columns: 250px 1fr;
		gap: 1.5rem;
		align-items: start;
		padding-bottom: 1.75rem;
		border-bottom: 1px solid var(--shadow-color);
	}

	.publication-card:last-child {
		padding-bottom: 0;
		border-bottom: none;
	}

	/* Left column: thumbnail with the action links stacked beneath it */
	.pub-aside {
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
		width: 250px;
	}

	.pub-thumb {
		display: block;
		width: 100%;
		border-radius: 8px;
		overflow: hidden;
		border: 1px solid var(--shadow-color);
		line-height: 0;
	}

	/* Height follows the image's own aspect ratio, so no grey letterboxing shows */
	.pub-thumb img {
		width: 100%;
		height: auto;
		display: block;
		transition: transform 0.3s ease;
	}

	a.pub-thumb:hover img {
		transform: scale(1.04);
	}

	/* Placeholder (papers without an image) keeps a fixed 16:9 frame */
	.pub-thumb .placeholder-image {
		aspect-ratio: 16 / 9;
	}

	.placeholder-image {
		width: 100%;
		height: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
		background: linear-gradient(135deg, var(--block-color) 0%, var(--shadow-color) 100%);
	}

	.year-badge {
		font-size: 2rem;
		font-weight: bold;
		color: var(--secondary-color);
	}

	.pub-body {
		min-width: 0;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.pub-venue-row {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.pub-venue {
		display: inline-block;
		max-width: 100%;
		font-family: var(--monospace);
		font-size: 0.72rem;
		letter-spacing: 0.02em;
		line-height: 1.5;
		color: var(--accent);
		background-color: var(--accent-soft);
		border: 1px solid rgba(180, 83, 9, 0.22);
		border-radius: 4px;
		padding: 2px 9px;
		overflow-wrap: break-word;
	}

	.publication-title {
		font-size: 1.15rem;
		font-weight: 600;
		line-height: 1.4;
		color: var(--primary-color);
		margin: 0;
	}

	.publication-title a {
		color: inherit;
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.publication-title a:hover {
		color: var(--accent);
	}

	.publication-topics {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin: 0;
	}

	.topic-tag {
		display: inline-block;
		max-width: 100%;
		padding: 0.15rem 0.6rem;
		background: var(--block-color);
		color: var(--secondary-color);
		border: 1px solid var(--shadow-color);
		border-radius: 12px;
		font-size: 0.75rem;
		line-height: 1.5;
		overflow-wrap: break-word;
	}

	.award-badge {
		display: inline-block;
		padding: 0.15rem 0.5rem;
		margin-left: 0.5rem;
		background-color: var(--accent-soft);
		color: var(--accent);
		font-weight: 600;
		font-size: 0.85rem;
		border-radius: 4px;
	}

	.publication-authors {
		font-size: 0.9rem;
		color: var(--remark-color);
		line-height: 1.6;
		margin: 0;
	}

	/* Action links sit under the text in the right column */
	.publication-links {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
		margin-top: 0.25rem;
	}

	.pub-link {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.35rem 0.85rem;
		background: var(--block-color);
		color: var(--accent);
		text-decoration: none;
		border-radius: 4px;
		font-size: 0.85rem;
		font-weight: 500;
		transition: background 0.2s ease, box-shadow 0.2s ease, transform 0.1s ease;
	}

	.pub-link:hover {
		background: var(--accent-soft);
		box-shadow: 0 2px 8px rgba(180, 83, 9, 0.15);
		transform: translateY(-1px);
	}

	.pub-link figure {
		margin: 0;
		line-height: 0;
	}

	/* Mobile Responsive */
	@media (max-width: 1024px) {
		.publications-container { grid-template-columns: 1fr; gap: 2rem; }
		.publications-sidebar {
			position: relative;
			top: 0;
			order: -1;
			flex-direction: row;
			flex-wrap: wrap;
			gap: 1.2rem 2.4rem;
		}
		.filter-scrollable { max-height: 150px; }
	}

	@media (max-width: 640px) {
		/* Stack thumbnail above text on narrow screens */
		.publication-card {
			grid-template-columns: 1fr;
			gap: 0.85rem;
		}

		.pub-aside {
			width: 100%;
			max-width: 420px;
		}

		.publication-title {
			font-size: 1.05rem;
		}

		.filter-label {
			font-size: 0.85rem;
		}
	}
</style>
