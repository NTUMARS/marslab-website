---
import { i18n } from "astro:config/client";
import { render, getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import { Icon } from "astro-icon/components";
import Time from "$utils/time";
import Base from "$layouts/Base.astro";
import config from "$config";
import i18nit from "$i18n";
import { people } from "$data/people";

export async function getStaticPaths() {
	return i18n!.locales.map(locale => ({ params: { locale: locale == i18n?.defaultLocale ? undefined : (locale as string) } }));
}

const { locale = i18n!.defaultLocale } = Astro.params;

const t = i18nit(locale);
const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';

// Preface (intro paragraph) — newest first
const prefaces = (
	await getCollection("preface", preface => {
		const [, id] = preface.id.split("/");
		preface.id = id;
		return true;
	})
).sort((a, b) => b.data.timestamp.getTime() - a.data.timestamp.getTime());
const preface = prefaces[0];
const { Content } = preface ? await render(preface) : ({} as any);

// Anchor ids must match the People page exactly
const slugify = (name: string) => name.toLowerCase().replace(/[^a-z]/g, '');

const peopleWithImages = people.filter(person => person.image);

// ---- Member face marquee (home hero centre): horizontal rows, adjacent rows scroll opposite ----
// (The rotating constellation now lives on its own /constellation page, opened from the logo.)
const FACE_ROWS = 3;
// Give each row a DISJOINT slice of members so the same face never appears in two
// rows at once. Each slice is then repeated enough to span the viewport, so the
// marquee (markup duplicates the row once and scrolls -50%) loops without gaps.
const perRow = Math.ceil(peopleWithImages.length / FACE_ROWS);
const MIN_TILES = 12;
const faceRows = Array.from({ length: FACE_ROWS }, (_, r) => {
	const group = peopleWithImages.slice(r * perRow, (r + 1) * perRow);
	if (group.length === 0) return group;
	const reps = Math.ceil(MIN_TILES / group.length);
	return Array.from({ length: reps }, () => group).flat();
});

// ---- Robotic platforms (side vertical marquee) ----
const robots = [
	{ name: "Unitree G1", type: "Humanoid", qty: 2, image: "/equipment/unitree-g1.jpg" },
	{ name: "ROKAE Human.X", type: "Humanoid", qty: 3, image: "/equipment/rokae-humanx.jpg" },
	{ name: "Galaxea R1 Lite", type: "Mobile Manipulator", qty: 1, image: "/equipment/galaxea-r1.jpg" },
	{ name: "Franka Panda", type: "Robot Arm", qty: 1, image: "/equipment/franka-panda.jpg" },
	{ name: "UR5e", type: "Robot Arm", qty: 1, image: "/equipment/ur5e.jpg" },
	{ name: "UFactory xArm", type: "Robot Arm", qty: 1, image: "/equipment/ufactory-xarm.jpg" },
	{ name: "Sharpa Wave", type: "Dexterous Hand", qty: 2, image: "/equipment/sharpa-wave.jpg" },
];
const robotsLeft = robots;
const robotsRight = [...robots].reverse();

// ---- News (structured; show half, expand the rest) ----
const news = [
	{ month: "Apr 2026",     text: 'Our paper <a href="https://arxiv.org/abs/2602.07322" target="_blank" rel="noopener noreferrer" class="news-link">A2A</a> was accepted. Congratulations to Jindou Jia and Gen Li!', venue: "RSS 2026" },
	{ month: "Mar 2026",     text: "We received an NVIDIA Academic Grant on Robotics." },
	{ month: "Feb 2026",  text: "Three papers (two main + one findings) were accepted.", venue: "CVPR 2026" },
	{ month: "Feb 2026",  text: "We received a Microsoft Seed Grant from Microsoft Research Asia." },
	{ month: "Jan 2026",   text: "Our real-world reinforcement learning paper was accepted. Congratulations to Xiangyu Chen!", venue: "ICRA 2026" },
	{ month: "Jan 2026",   text: "Two papers were accepted. Congratulations to Xinyan Chen and Chenxi Jiang!", venue: "ICLR 2026" },
	{ month: "Nov 2025",  text: "Three papers were accepted.", venue: "AAAI 2026" },
	{ month: "Sep 2025", text: "Three papers — HoloLLM, Benford's Curse, and Intend to Move — were accepted.", venue: "NeurIPS 2025" },
	{ month: "Aug 2025",    text: "We welcomed five new members to the lab." },
	{ month: "Jun 2025",      text: "Two papers were accepted.", venue: "IROS 2025" },
	{ month: "May 2025",       text: "Our humanoid robot MARS-H joined the lab." },
	{ month: "Feb 2025",  text: "We established a partnership with Abio for robotic lab automation." },
	{ month: "Feb 2025",  text: "Our project was supported by Microsoft Accelerating Foundation Models Research." },
	{ month: "Feb 2025",  text: "Our Feedback Neural Network paper was selected as an oral (top 1.8%).", venue: "ICLR 2025" },
	{ month: "Jan 2025",   text: "Two papers — X-Fi and Feedback Neural Network — were accepted.", venue: "ICLR 2025" },
	{ month: "Jan 2025",   text: "Our point registration paper was accepted. Congratulations to Geng Li!", venue: "ICRA 2025" },
	{ month: "Jan 2025",   text: "The lab joined Project Aria by Meta." },
	{ month: "Sep 2024", text: "Chuhao Zhou won first place at the Data Distillation Challenge.", venue: "ECCV 2024" },
	{ month: "Sep 2024", text: "The MARS Lab officially launched at the Robotics Research Centre, NTU." },
];
const NEWS_VISIBLE = 9;
const newsHead = news.slice(0, NEWS_VISIBLE);
const newsTail = news.slice(NEWS_VISIBLE);

// ---- Lab highlights / events — horizontal scroller (non-clickable cards) ----
const events = [
	{ image: "/events/supply-chain-2026.jpg",  title: "Robotics Supply-Chain Workshop", meta: "Singapore · 2026" },
	{ image: "/events/mae-high-tea.jpg",       title: "MAE High Tea",                   meta: "NTU MAE · Student Outreach" },
	{ image: "/events/roboexchange.jpg",      title: "RoboNexus Exchange",             meta: "NTU MARS Lab × NRP" },
];

// ---- Collaborating institutions — auto-scrolling logo marquee (logos in public/partners/) ----
// Detailed crests rasterized to small color PNGs (svg seals were 100–470KB → slow); wordmarks stay svg.
const partners = [
	{ file: "stanford.png",  name: "Stanford University" },
	{ file: "berkeley.png",  name: "UC Berkeley" },
	{ file: "harvard.png",   name: "Harvard University" },
	{ file: "mit.svg",       name: "MIT" },
	{ file: "eth.svg",       name: "ETH Zürich" },
	{ file: "oxford.png",    name: "University of Oxford" },
	{ file: "princeton.png", name: "Princeton University" },
	{ file: "nvidia.svg",    name: "NVIDIA" },
	{ file: "google.svg",    name: "Google" },
	{ file: "microsoft.svg", name: "Microsoft" },
	{ file: "sharpa.svg",    name: "Sharpa" },
	{ file: "rokae.png",     name: "ROKAE" },
	{ file: "unitree.svg",   name: "Unitree" },
];
---

<Base title={t("navigation.home")} {locale}>
	<main class="flex flex-col gap-6 sm:gap-12 flex-grow">
		<!-- Hero: robotic platforms scroll on the sides; members orbit the PI in the center -->
		<section class="showcase" aria-label="MARS Lab members and robotic platforms">
			<div class="showcase-col">
				<div class="v-track v-up">
					{[...robotsLeft, ...robotsLeft].map((r) => (
						<article class="robot-tile">
							<div class="robot-photo">
								<img src={`${baseUrl}${r.image.replace(/^\//, '')}`} alt={r.name} loading="lazy" />
								<span class="robot-qty">×{r.qty}</span>
							</div>
							<div class="robot-meta">
								<span class="robot-name">{r.name}</span>
								<span class="robot-type">{r.type}</span>
							</div>
						</article>
					))}
				</div>
			</div>

			<div class="showcase-center">
				<div class="face-marquee" role="img" aria-label="MARS Lab members">
					{faceRows.map((row, ri) => (
						<div class="face-row">
							<div class:list={["face-track", { "face-track--rev": ri % 2 === 1 }]} style={`--dur:${60 + ri * 10}s`}>
								{[...row, ...row].map((person) => (
									<a class="face" href={getRelativeLocaleUrl(locale, `/people#${slugify(person.name)}`)} title={person.name} aria-label={person.name}>
										<img src={`${baseUrl}${person.image.replace(/^\//, '')}`} alt={person.name} loading="eager" decoding="async" width="80" height="80" />
									</a>
								))}
							</div>
						</div>
					))}
				</div>
			</div>

			<div class="showcase-col">
				<div class="v-track v-down">
					{[...robotsRight, ...robotsRight].map((r) => (
						<article class="robot-tile">
							<div class="robot-photo">
								<img src={`${baseUrl}${r.image.replace(/^\//, '')}`} alt={r.name} loading="lazy" />
								<span class="robot-qty">×{r.qty}</span>
							</div>
							<div class="robot-meta">
								<span class="robot-name">{r.name}</span>
								<span class="robot-type">{r.type}</span>
							</div>
						</article>
					))}
				</div>
			</div>
		</section>

		{
			preface && (
				<section class="flex flex-col">
					<article class="markdown">
						<Content />
					</article>
				</section>
			)
		}

		<!-- News timeline (show half, expand the rest — CSS only) -->
		<section class="news-section" aria-label="News">
			<h2 class="news-heading">News</h2>
			<ol class="news-list">
				{newsHead.map((n) => (
					<li class="news-item">
						<span class="news-month">{n.month}</span>
						<span class="news-body"><Fragment set:html={n.text} />{n.venue && <code class="news-venue">{n.venue}</code>}</span>
					</li>
				))}
			</ol>

			<input type="checkbox" id="news-toggle" class="news-toggle" aria-hidden="true" />

			<ol class="news-list news-extra">
				{newsTail.map((n) => (
					<li class="news-item">
						<span class="news-month">{n.month}</span>
						<span class="news-body"><Fragment set:html={n.text} />{n.venue && <code class="news-venue">{n.venue}</code>}</span>
					</li>
				))}
			</ol>

			<label for="news-toggle" class="news-more-btn">
				<span class="label-more">Show more</span>
				<span class="label-less">Show less</span>
				<svg class="chev" viewBox="0 0 16 16" aria-hidden="true"><path d="M4 6l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" /></svg>
			</label>
		</section>

		<!-- Highlights — horizontal-scrolling event cards (Prof. Yang's LinkedIn) -->
		<section class="events-section" aria-label="Lab highlights">
			<div class="events-head">
				<h2 class="events-heading">Highlights</h2>
				<div class="events-controls">
					<button class="ev-arrow ev-prev" type="button" aria-label="Scroll to previous" disabled>
						<svg viewBox="0 0 16 16" aria-hidden="true"><path d="M10 3L5 8l5 5" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
					</button>
					<button class="ev-arrow ev-next" type="button" aria-label="Scroll to next">
						<svg viewBox="0 0 16 16" aria-hidden="true"><path d="M6 3l5 5-5 5" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
					</button>
				</div>
			</div>

			<div class="events-scroller">
				{events.map((e) => (
					<article class="event-card">
						<div class="event-photo">
							<img src={`${baseUrl}${e.image.replace(/^\//, '')}`} alt={e.title} loading="lazy" />
						</div>
						<div class="event-caption">
							<span class="event-meta">{e.meta}</span>
							<span class="event-title">{e.title}</span>
						</div>
					</article>
				))}
			</div>
		</section>

		<!-- Collaborators — auto-scrolling logo marquee -->
		<section class="partners-section" aria-label="Collaborating institutions">
			<h2 class="partners-heading">Collaborators</h2>
			<div class="partners-marquee">
				<div class="partners-track">
					{[...partners, ...partners].map((p) => (
						<div class="partner" title={p.name}>
							<div class="partner-logo">
								<img src={`${baseUrl}partners/${p.file}`} alt={p.name} loading="eager" decoding="async" />
							</div>
							<span class="partner-name">{p.name}</span>
						</div>
					))}
				</div>
			</div>
		</section>
	</main>
</Base>

<style>
	/* ===================== HERO SHOWCASE ===================== */
	.showcase {
		display: flex;
		align-items: stretch;
		justify-content: center;
		gap: clamp(0.6rem, 2.2vw, 1.6rem);
		height: 350px;
		margin-top: 0.25rem;
		overflow: hidden;
	}

	/* --- side robot columns: vertical marquee --- */
	.showcase-col {
		position: relative;
		width: 146px;
		flex: 0 0 146px;
		overflow: hidden;
		-webkit-mask-image: linear-gradient(180deg, transparent, #000 9%, #000 91%, transparent);
		        mask-image: linear-gradient(180deg, transparent, #000 9%, #000 91%, transparent);
	}
	.v-track {
		display: flex;
		flex-direction: column;
		gap: 0.85rem;
		will-change: transform;
	}
	.v-up   { animation: v-up   40s linear infinite; }
	.v-down { animation: v-down 40s linear infinite; }
	.showcase-col:hover .v-track { animation-play-state: paused; }

	.robot-tile {
		flex: 0 0 auto;
		border: 1px solid var(--shadow-color);
		border-radius: 12px;
		overflow: hidden;
		background: linear-gradient(180deg, var(--background-color) 0%, var(--block-color) 100%);
		box-shadow: 0 2px 8px rgba(42, 42, 40, 0.07);
		transition: box-shadow 0.25s ease, border-color 0.25s ease, transform 0.25s ease;
	}
	.robot-tile:hover {
		border-color: var(--remark-color);
		box-shadow: 0 9px 22px rgba(42, 42, 40, 0.14);
		transform: translateY(-2px);
	}
	.robot-photo { position: relative; aspect-ratio: 1 / 1; overflow: hidden; }
	.robot-photo img { width: 100%; height: 100%; object-fit: cover; display: block; background: var(--block-color); }
	.robot-qty {
		position: absolute;
		top: 8px; right: 8px;
		font-family: var(--monospace);
		font-size: 0.72rem;
		letter-spacing: 0.02em;
		color: #fff;
		background: linear-gradient(135deg, var(--accent) 0%, var(--accent-deep) 100%);
		border-radius: 999px;
		padding: 1px 8px;
		box-shadow: 0 1px 4px rgba(42, 42, 40, 0.24);
	}
	.robot-meta {
		display: flex; flex-direction: column; gap: 2px;
		padding: 0.5rem 0.7rem 0.65rem;
		border-top: 1px solid var(--block-color);
	}
	.robot-name { font-size: 0.88rem; font-weight: 700; line-height: 1.2; color: var(--primary-color); }
	.robot-type {
		font-family: var(--monospace);
		font-size: 0.6rem; letter-spacing: 0.09em;
		text-transform: uppercase;
		color: var(--remark-color);
	}

	@keyframes v-up   { from { transform: translateY(0); }    to { transform: translateY(-50%); } }
	@keyframes v-down { from { transform: translateY(-50%); } to { transform: translateY(0); } }

	/* --- center: member face marquee (horizontal rows, adjacent rows scroll opposite) --- */
	.showcase-center { flex: 1 1 auto; min-width: 0; display: flex; align-items: center; justify-content: center; }

	.face-marquee {
		display: flex; flex-direction: column; justify-content: center;
		gap: 6px; width: 100%; height: 100%;
		/* fade the rows out toward the left/right edges */
		-webkit-mask-image: linear-gradient(90deg, transparent, #000 9%, #000 91%, transparent);
		        mask-image: linear-gradient(90deg, transparent, #000 9%, #000 91%, transparent);
	}
	/* taller than the avatar so the hover lift never gets clipped */
	.face-row { display: flex; align-items: center; height: 104px; overflow: hidden; }
	.face-track {
		display: flex; gap: 20px; width: max-content;
		animation: face-left var(--dur) linear infinite;
		will-change: transform;
	}
	.face-track--rev { animation-name: face-right; }
	.face-row:hover .face-track { animation-play-state: paused; }

	@keyframes face-left  { from { transform: translateX(0); }    to { transform: translateX(-50%); } }
	@keyframes face-right { from { transform: translateX(-50%); } to { transform: translateX(0); } }

	/* rounded squares — same shape as the People page (border-radius 8px), not circles */
	.face { flex: 0 0 auto; display: block; width: 80px; height: 80px; border-radius: 8px; }
	.face img {
		width: 100%; height: 100%; border-radius: 8px; object-fit: cover; display: block;
		border: 2px solid var(--background-color);
		box-shadow: 0 3px 11px rgba(42, 42, 40, 0.15), 0 0 0 1px rgba(42, 42, 40, 0.05);
		background: var(--block-color);
		transition: transform 0.3s cubic-bezier(0.22, 0.68, 0.28, 1), box-shadow 0.3s ease;
	}
	/* identical lift for every avatar (uniform size) */
	.face:hover img,
	.face:focus-visible img {
		transform: scale(1.12);
		box-shadow: 0 10px 24px rgba(42, 42, 40, 0.22), 0 0 0 2px var(--accent);
	}

	@media (prefers-reduced-motion: reduce) {
		.v-track, .face-track, .partners-track { animation: none !important; }
	}

	/* ===================== NEWS TIMELINE ===================== */
	.news-section { display: flex; flex-direction: column; }
	.news-heading {
		font-size: 1.6rem; font-weight: 700;
		padding-bottom: 0.4rem; margin-bottom: 0.3rem;
		border-bottom: 1px solid var(--shadow-color);
	}
	.news-list { list-style: none; margin: 0; padding: 0; }
	.news-item {
		display: grid; grid-template-columns: 136px 1fr; gap: 0.85rem;
		align-items: baseline; padding: 0.72rem 0;
	}
	.news-month { font-weight: 700; font-size: 0.9rem; color: var(--primary-color); white-space: nowrap; }
	.news-body { font-size: 0.93rem; line-height: 1.55; color: var(--secondary-color); }
	/* Inline paper links inside a news line (e.g. A2A → arXiv) */
	.news-link {
		color: var(--accent);
		font-weight: 600;
		text-decoration: none;
		border-bottom: 1px solid transparent;
		transition: border-color 0.18s ease, color 0.18s ease;
	}
	.news-link:hover { color: var(--accent-deep); border-bottom-color: currentColor; }
	/* Venue is plain emphasis text — no badge box; KaTeX (Computer Modern) for a LaTeX/math feel,
	   bold amber for key venues (CVPR, RSS 2026…) */
	.news-venue {
		margin-left: 0.45rem;
		font-family: "KaTeX_Main", var(--serif); font-size: 0.95rem; letter-spacing: 0;
		color: var(--accent);
		font-weight: 700;
		background: none; border: none; padding: 0;
	}

	.news-toggle { position: absolute; width: 1px; height: 1px; opacity: 0; pointer-events: none; }
	.news-extra { max-height: 0; opacity: 0; overflow: hidden; transition: max-height 0.45s ease, opacity 0.35s ease; }
	.news-toggle:checked ~ .news-extra { max-height: 900px; opacity: 1; }

	.news-more-btn {
		align-self: center;
		display: inline-flex; align-items: center; gap: 0.5rem;
		margin-top: 1.3rem; padding: 0.55rem 1.4rem;
		font-size: 0.82rem; font-weight: 500; letter-spacing: 0.03em;
		color: var(--secondary-color);
		background: linear-gradient(180deg, var(--background-color) 0%, var(--block-color) 100%);
		border: 1px solid var(--shadow-color);
		border-radius: 999px;
		box-shadow: 0 1px 2px rgba(42, 42, 40, 0.05);
		cursor: pointer; user-select: none;
		transition: border-color 0.22s ease, color 0.22s ease, box-shadow 0.25s ease, transform 0.22s ease;
	}
	.news-more-btn:hover {
		border-color: var(--accent); color: var(--accent);
		box-shadow: 0 6px 16px rgba(42, 42, 40, 0.10);
		transform: translateY(-1px);
	}
	.chev { width: 14px; height: 14px; transition: transform 0.32s ease; }
	.label-less { display: none; }
	.news-toggle:checked ~ .news-more-btn .label-more { display: none; }
	.news-toggle:checked ~ .news-more-btn .label-less { display: inline; }
	.news-toggle:checked ~ .news-more-btn .chev { transform: rotate(180deg); }
	.news-toggle:focus-visible ~ .news-more-btn { outline: 2px solid var(--accent); outline-offset: 2px; }

	/* ===================== HIGHLIGHTS (horizontal events) ===================== */
	.events-section { display: flex; flex-direction: column; gap: 1.15rem; }
	.events-head {
		display: flex; align-items: flex-end; justify-content: space-between; gap: 1rem;
		padding-bottom: 0.4rem; border-bottom: 1px solid var(--shadow-color);
	}
	.events-heading { font-size: 1.6rem; font-weight: 700; margin: 0; line-height: 1.1; }
	.events-controls { display: flex; align-items: center; gap: 0.7rem; }
	.ev-arrow {
		display: inline-flex; align-items: center; justify-content: center;
		width: 34px; height: 34px; flex: 0 0 auto;
		border: 1px solid var(--shadow-color); border-radius: 999px;
		background: var(--background-color); color: var(--primary-color);
		cursor: pointer;
		transition: border-color 0.2s ease, color 0.2s ease, transform 0.15s ease, opacity 0.2s ease;
	}
	.ev-arrow svg { width: 15px; height: 15px; }
	.ev-arrow:hover:not(:disabled) { border-color: var(--accent); color: var(--accent); transform: translateY(-1px); }
	.ev-arrow:disabled { opacity: 0.3; cursor: default; }

	.events-scroller {
		display: flex; gap: 1.25rem;
		overflow-x: auto;
		padding: 0.3rem 0.25rem 1rem; margin: 0 -0.25rem;
		scrollbar-width: none;
		-webkit-mask-image: linear-gradient(90deg, #000 0, #000 94%, transparent 100%);
		        mask-image: linear-gradient(90deg, #000 0, #000 94%, transparent 100%);
	}
	.events-scroller::-webkit-scrollbar { display: none; }

	.event-card {
		flex: 0 0 clamp(300px, 44%, 440px);
		scroll-snap-align: start;
		display: flex; flex-direction: column;
		text-decoration: none; color: inherit;
		transition: transform 0.32s cubic-bezier(0.22, 0.68, 0.28, 1);
	}
	.event-photo {
		width: 100%; aspect-ratio: 3 / 2; overflow: hidden;
		border-radius: 14px; border: 1px solid var(--shadow-color);
		background: var(--block-color);
		box-shadow: 0 4px 14px rgba(42, 42, 40, 0.08);
		transition: box-shadow 0.32s ease, border-color 0.32s ease;
	}
	.event-photo img {
		width: 100%; height: 100%; object-fit: cover; display: block;
		transition: transform 0.5s cubic-bezier(0.22, 0.68, 0.28, 1);
	}
	.event-card:hover { transform: translateY(-4px); }
	.event-card:hover .event-photo { box-shadow: 0 16px 34px rgba(42, 42, 40, 0.16); border-color: var(--remark-color); }
	.event-card:hover .event-photo img { transform: scale(1.045); }

