---
import Base from "$layouts/Base.astro";
---

<Base title="404">
	{/* Catch-all for the OLD site's URLs still indexed by search engines. The new
	    Astro site reorganised everything, so old links 404. Two rules:
	      1. per-member pages  /members/<slug>.html  -> /people/#<anchor>
	         (card ids = name lowercased to letters only, so the hyphenated old slug
	          maps straight onto the anchor by stripping non-letters)
	      2. old top-level pages (/team, /home, /about, ...) -> the closest new page */}
	<script is:inline>
		(function () {
			var path = location.pathname.replace(/\/+$/, "");            // drop trailing slash(es)
			var m = path.match(/\/members\/(.+?)(?:\.html?)?$/i);        // 1. per-member page
			if (m && m[1]) {
				var anchor = decodeURIComponent(m[1]).toLowerCase().replace(/[^a-z]/g, "");
				if (anchor) { location.replace("/people/#" + anchor); return; }
			}
			var key = path.replace(/\.html?$/i, "").toLowerCase();      // 2. old top-level page
			var map = {
				"/team": "/people/", "/members": "/people/",
				"/home": "/", "/about": "/", "/news": "/", "/research": "/",
				"/join": "/contact/"
			};
			if (map[key]) location.replace(map[key]);
		})();
	</script>
	<main class="contents">
		<div class="inline-flex flex-col items-center justify-center gap-2 text-center grow-0.5 animate-shaky">
			<span class="text-6xl font-bold">404</span>
			<span class="text-2xl">Not Found</span>
		</div>
		<a href="/" class="text-lg text-center link">&gt; Back</a>
	</main>
</Base>
