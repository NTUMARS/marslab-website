---
import config from "$config";

const { title, subtitle, description, author, article } = Astro.props;
const gaId = (config as { gaMeasurementId?: string }).gaMeasurementId;
const gaEnabled = !!gaId && /^G-[A-Z0-9]+$/.test(gaId) && gaId !== "G-XXXXXXXXXX";
const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

<html lang={Astro.currentLocale} class="no-js">
	<head>
		<title>{subtitle && `${subtitle} |`} {title}</title>
		<meta name="description" content={description} />

		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />

	<meta property="og:title" content={`${subtitle && `${subtitle} | `}${title}`} />
	<meta property="og:type" content={(article && "article") || "website"} />
	<meta property="og:image" content={new URL(`${baseUrl}mars_lab_logo_black.png`, Astro.site)} />
	<meta property="og:description" content={description} />
	<meta property="og:url" content={new URL(Astro.url.pathname, Astro.site)} />

	{article && [<meta property="article:author" content={author} />, <meta property="article:published_time" content={article.timestamp.toISOString()} />, article.section && <meta property="article:section" content={article.section} />, article.tags?.map((tag: string) => <meta property="article:tag" content={tag} />)]}

	<link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
	<link rel="icon" type="image/png" href={`${baseUrl}favicon-96x96.png`} sizes="96x96" />
	<link rel="shortcut icon" href={`${baseUrl}favicon.ico`} />
	<link rel="apple-touch-icon" sizes="180x180" href={`${baseUrl}apple-touch-icon.png`} />
	<meta name="apple-mobile-web-app-title" content={title} />
	<link rel="manifest" href={`${baseUrl}site.webmanifest`} />
	<link rel="sitemap" href={`${baseUrl}sitemap-index.xml`} />

		<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@200..900&family=Noto+Serif:ital,wght@1,200..900&family=Playwrite+MX:wght@100..400&display=swap" onload="this.onload=null;this.rel='stylesheet'" />
		<link rel="preload" as="style" href="https://fontsapi.zeoseven.com/442/main/result.css" onload="this.onload=null;this.rel='stylesheet'" />
		<link rel="preload" as="style" href="https://fontsapi.zeoseven.com/556/main/result.css" onload="this.onload=null;this.rel='stylesheet'" />
		<link rel="preload" as="style" href="https://cdnjs.cloudflare.com/ajax/libs/KaTeX/0.16.4/katex.min.css" onload="this.onload=null;this.rel='stylesheet'" />

		{(Astro.currentLocale === "zh-hk" || Astro.currentLocale === "zh-mo") && <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Noto+Serif+HK:wght@200..900&display=swap" onload="this.onload=null;this.rel='stylesheet'" />}
		{Astro.currentLocale === "zh-tw" && <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@200..900&display=swap" onload="this.onload=null;this.rel='stylesheet'" />}
		{Astro.currentLocale === "ja" && <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@200..900&display=swap" onload="this.onload=null;this.rel='stylesheet'" />}
		{Astro.currentLocale === "ko" && <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@200..900&display=swap" onload="this.onload=null;this.rel='stylesheet'" />}

		<script is:inline>
			// Always use light theme
			document.documentElement.dataset.theme = "light";
			// Flip no-js -> js before first paint. This persists across Swup navigations (the
			// <html> element is never swapped), so any html.no-js-gated fallback stays inert
			// once JS has loaded — including after navigating back to a page via Swup.
			document.documentElement.classList.remove("no-js");
			document.documentElement.classList.add("js");
		</script>

		{gaEnabled && (
			<>
				<script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
				<script is:inline define:vars={{ gaId }}>
					window.dataLayer = window.dataLayer || [];
					function gtag() { window.dataLayer.push(arguments); }
					window.gtag = gtag;
					gtag("js", new Date());
					// Disable automatic page_view — we send it manually so Swup transitions are tracked.
					gtag("config", gaId, { send_page_view: false });

					(function () {
						if (window.__gaTrackingInit) return;
						window.__gaTrackingInit = true;

						function sendPageView() {
							gtag("event", "page_view", {
								page_title: document.title,
								page_location: window.location.href,
								page_path: window.location.pathname + window.location.search,
							});
						}

						// Initial pageview (full document load).
						sendPageView();

						// Re-send on every Swup client-side navigation.
						function bindSwupPageView() {
							if (!window.swup || !window.swup.hooks) return false;
							window.swup.hooks.on("page:view", sendPageView);
							return true;
						}
						if (!bindSwupPageView()) {
							document.addEventListener("swup:enable", bindSwupPageView);
						}

						var FILE_EXT = /\.(pdf|bib|zip|tar|gz|csv|txt|doc|docx|ppt|pptx|xls|xlsx|json|mp4|mov|wav|mp3)(\?.*)?$/i;

						// Delegated click handler — capture-phase so it survives Swup DOM swaps without rebinding.
						document.addEventListener("click", function (event) {
							var target = event.target;
							if (!(target instanceof Element)) return;
							var link = target.closest("a");
							if (!link || !link.href) return;

							var href = link.getAttribute("href") || "";
							var url;
							try { url = new URL(link.href, window.location.href); } catch (e) { return; }

							var linkText = (link.innerText || link.textContent || "").trim().slice(0, 100);

							// Mailto
							if (href.indexOf("mailto:") === 0) {
								gtag("event", "email_click", {
									link_url: href,
									link_text: linkText,
									page_path: window.location.pathname,
								});
								return;
							}

							// File downloads
							if (FILE_EXT.test(url.pathname)) {
								var ext = (url.pathname.match(FILE_EXT) || [, ""])[1].toLowerCase();
								gtag("event", "file_download", {
									file_url: url.href,
									file_name: url.pathname.split("/").pop(),
									file_extension: ext,
									link_text: linkText,
									page_path: window.location.pathname,
								});
								// Don't return — also tag outbound below if applicable.
							}

							// Outbound link
							var isHttp = url.protocol === "http:" || url.protocol === "https:";
							if (isHttp && url.hostname && url.hostname !== window.location.hostname) {
								gtag("event", "click", {
									outbound: true,
									link_domain: url.hostname,
									link_url: url.href,
									link_text: linkText,
									page_path: window.location.pathname,
								});
							}

							// Publication card click — fires when user clicks anywhere inside an .publication-card link.
							var card = link.closest(".publication-card");
							if (card) {
								gtag("event", "publication_click", {
									publication_title: (card.querySelector(".publication-title") || {}).textContent || undefined,
									publication_year: card.getAttribute("data-year") || undefined,
									publication_venue: card.getAttribute("data-venue") || undefined,
									link_kind: link.classList.contains("pub-link") ? (linkText || "pub-link") : "card",
									link_url: url.href,
								});
							}
						}, true);

						// Scroll depth tracking — fires once each at 25/50/75/100% per page.
						var depthHit = { 25: false, 50: false, 75: false, 100: false };
						function resetDepth() { depthHit = { 25: false, 50: false, 75: false, 100: false }; }
						function onScroll() {
							var doc = document.documentElement;
							var scrollTop = window.scrollY || doc.scrollTop || 0;
							var viewport = window.innerHeight || doc.clientHeight || 0;
							var fullHeight = Math.max(doc.scrollHeight, document.body ? document.body.scrollHeight : 0);
							var scrollable = fullHeight - viewport;
							if (scrollable <= 0) return;
							var pct = Math.min(100, Math.round(((scrollTop + viewport) / fullHeight) * 100));
							[25, 50, 75, 100].forEach(function (threshold) {
								if (!depthHit[threshold] && pct >= threshold) {
									depthHit[threshold] = true;
									gtag("event", "scroll", {
										percent_scrolled: threshold,
										page_path: window.location.pathname,
									});
								}
							});
						}
						var scrollTimer = null;
						window.addEventListener("scroll", function () {
							if (scrollTimer) return;
							scrollTimer = window.setTimeout(function () {
								scrollTimer = null;
								onScroll();
							}, 250);
						}, { passive: true });

						// Reset scroll depth on each Swup navigation.
						function bindSwupScrollReset() {
							if (!window.swup || !window.swup.hooks) return false;
							window.swup.hooks.on("page:view", resetDepth);
							return true;
						}
						if (!bindSwupScrollReset()) {
							document.addEventListener("swup:enable", bindSwupScrollReset);
						}
					})();
				</script>
			</>
		)}
	</head>
	<body>
		<slot />
	</body>
</html>
